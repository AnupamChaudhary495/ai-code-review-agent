  "raw_url": "https://github.com/AnupamChaudhary495/review-agent-webhook-test/raw/dcdb60a76c1513cac1bdbe818fdc3e6517c8b36b/perf%2Fn_plus_one.py",
  "contents_url": "https://api.github.com/repos/AnupamChaudhary495/review-agent-webhook-test/contents/perf%2Fn_plus_one.py?ref=dcdb60a76c1513cac1bdbe818fdc3e6517c8b36b",
  "patch": "@@ -0,0 +1,7 @@\n+def order_totals(user_ids, db):\n+    totals = {}\n+    for uid in user_ids:\n+        user = db.session.query(User).get(uid)\n+        orders = db.session.query(Order).filter(Order.user_id == uid).all()\n+        totals[user.name] = sum(o.amount for o in orders)\n+    return totals"
 },
