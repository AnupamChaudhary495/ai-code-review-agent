  "patch": "@@ -0,0 +1,7 @@\n+def find_duplicate_keys(records):\n+    duplicates = []\n+    for i in range(len(records)):\n+        for j in range(len(records)):\n+            if i != j and records[i].key == records[j].key:\n+                duplicates.append(records[i].key)\n+    return duplicates"
