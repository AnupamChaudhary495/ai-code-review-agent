  "contents_url": "https://api.github.com/repos/AnupamChaudhary495/review-agent-webhook-test/contents/eval%2Fsql_query.py?ref=2e0e3fd3d4d06261024b41c530de41719c936904",
  "patch": "@@ -0,0 +1,10 @@\n+import sqlite3\n+\n+\n+def find_user(db_path, username):\n+    conn = sqlite3.connect(db_path)\n+    cursor = conn.cursor()\n+    cursor.execute(f\"SELECT id, email FROM users WHERE username = '{username}'\")\n+    row = cursor.fetchone()\n+    conn.close()\n+    return row"
 }
