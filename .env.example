# Copy to .env and fill in. Never commit .env.

# Shared secret configured on the GitHub webhook. Required — the webhook
# endpoint refuses requests until this is set.
GITHUB_WEBHOOK_SECRET=

# Anthropic API key for the review LLM call.
ANTHROPIC_API_KEY=

# GitHub App credentials (Phase 2). App ID from the App settings page;
# private key is the downloaded PEM — either paste with real newlines in a
# multiline-capable env, or as a single line with \n escapes.
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=

# Model must support adaptive thinking (Claude 4.6 family or newer).
LLM_MODEL=claude-opus-4-8

# Overridden by docker-compose for the containerized app.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/review_agent

LOG_LEVEL=INFO
